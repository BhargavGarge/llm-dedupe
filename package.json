{
  "name": "llm-dedupe",
  "version": "1.0.0",
  "description": "Deduplicates identical in-flight LLM API requests — one real call, zero duplicate token spend.",
  "keywords": [
    "llm",
    "deduplication",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "memoize",
    "request-dedup",
    "cost-savings"
  ],
  "type": "module",
  "author": "BhargavGarge <bhargaavvv@gmail.com>",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "npm run build:esm && npm run build:cjs && npm run build:types && node scripts/fix-cjs-pkg.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.cjs.json",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run clean && npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
